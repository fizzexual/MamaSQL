# MamaSQL — copy this file to ".env" and edit as needed.
#   cp .env.example .env

# Which published image tag to run ("latest", or a version like "v0.1.0").
MAMASQL_VERSION=latest

# Host port for the web UI (open http://localhost:<WEB_PORT>).
WEB_PORT=5001

# Demo database credentials (used by the bundled postgres/mysql services).
DB_USERNAME=mamasql
DB_PASSWORD=mamasql
DB_DATABASE=demo

# Host ports for the demo databases (only needed for direct/external access).
PG_PORT=5433
MYSQL_PORT=3307
